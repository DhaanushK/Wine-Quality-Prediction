import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

from tensorflow import keras
from keras.models import Model
from keras.layers import Dense, Dropout, Conv1D, MaxPooling1D, Flatten, Input, concatenate
from keras.optimizers import Adam
from keras.callbacks import EarlyStopping, ModelCheckpoint
from keras.regularizers import l2

from sklearn.preprocessing import StandardScaler, OneHotEncoder
from sklearn.model_selection import train_test_split
from sklearn.neural_network import MLPClassifier

# Load dataset
data = pd.read_csv('/content/winequality-white-balanced (1).csv')

# Basic info
print(data.head())
print(data.describe())

# Features & target
y = data['quality']
X = data.drop('quality', axis=1)

print(y.shape, X.shape)

# Correlation heatmap
plt.figure(figsize=(12, 12))
sns.heatmap(data.astype(float).corr(), annot=True, cmap='viridis')
plt.title("Correlation of Features")
plt.show()

# Train-test split
seed = 8
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.2, random_state=seed
)

# Standardization
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# One-hot encoding
encoder = OneHotEncoder()
y_train_encoded = encoder.fit_transform(y_train.values.reshape(-1, 1)).toarray()
y_test_encoded = encoder.transform(y_test.values.reshape(-1, 1)).toarray()

# Reshape for CNN
X_train_cnn = X_train_scaled.reshape(X_train_scaled.shape[0], X_train_scaled.shape[1], 1)
X_test_cnn = X_test_scaled.reshape(X_test_scaled.shape[0], X_test_scaled.shape[1], 1)

# CNN branch
def create_cnn_branch(input_layer):
    x = Conv1D(32, kernel_size=2, activation='relu', padding='same',
               kernel_regularizer=l2(0.01))(input_layer)
    x = MaxPooling1D(pool_size=2)(x)

    x = Conv1D(64, kernel_size=2, activation='relu', padding='same',
               kernel_regularizer=l2(0.01))(x)
    x = MaxPooling1D(pool_size=2)(x)

    x = Flatten()(x)
    return x

# Split into 2 channels
split = X_train_cnn.shape[1] // 2

input1 = Input(shape=(split, 1))
input2 = Input(shape=(X_train_cnn.shape[1] - split, 1))

branch1 = create_cnn_branch(input1)
branch2 = create_cnn_branch(input2)

merged = concatenate([branch1, branch2])

# Dense layers
x = Dense(256, activation='relu', kernel_regularizer=l2(0.01))(merged)
x = Dropout(0.5)(x)

x = Dense(128, activation='relu', kernel_regularizer=l2(0.01))(x)
x = Dropout(0.5)(x)

x = Dense(64, activation='relu', kernel_regularizer=l2(0.01))(x)
x = Dropout(0.5)(x)

output_cnn = Dense(y_train_encoded.shape[1], activation='softmax')(x)

cnn_model = Model(inputs=[input1, input2], outputs=output_cnn)

cnn_model.compile(
    optimizer=Adam(learning_rate=0.0005),
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

# Callbacks
early_stop = EarlyStopping(monitor='val_loss', patience=10, restore_best_weights=True)
checkpoint = ModelCheckpoint('best_cnn_model.h5', save_best_only=True)

# Train CNN
cnn_model.fit(
    [X_train_cnn[:, :split, :], X_train_cnn[:, split:, :]],
    y_train_encoded,
    epochs=50,
    batch_size=64,
    validation_split=0.2,
    callbacks=[early_stop, checkpoint],
    verbose=1
)

# Evaluate CNN
cnn_model.load_weights('best_cnn_model.h5')

cnn_score = cnn_model.evaluate(
    [X_test_cnn[:, :split, :], X_test_cnn[:, split:, :]],
    y_test_encoded
)

print("CNN Accuracy:", cnn_score[1])

# MLP Model
mlp = MLPClassifier(hidden_layer_sizes=(256, 128, 64), max_iter=1000, random_state=seed)
mlp.fit(X_train_scaled, y_train)

mlp_train = mlp.predict_proba(X_train_scaled)
mlp_test = mlp.predict_proba(X_test_scaled)

print("MLP Accuracy:", mlp.score(X_test_scaled, y_test))

# Combined Model
mlp_input = Input(shape=(mlp_train.shape[1],))

cnn_flat = Flatten()(output_cnn)

combined = concatenate([cnn_flat, mlp_input])

x = Dense(128, activation='relu', kernel_regularizer=l2(0.01))(combined)
x = Dropout(0.5)(x)

x = Dense(64, activation='relu', kernel_regularizer=l2(0.01))(x)
x = Dropout(0.5)(x)

x = Dense(32, activation='relu', kernel_regularizer=l2(0.01))(x)
x = Dropout(0.5)(x)

final_output = Dense(y_train_encoded.shape[1], activation='softmax')(x)

combined_model = Model(
    inputs=[input1, input2, mlp_input],
    outputs=final_output
)

combined_model.compile(
    optimizer=Adam(learning_rate=0.0005),
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

# Train combined model
combined_model.fit(
    [X_train_cnn[:, :split, :], X_train_cnn[:, split:, :], mlp_train],
    y_train_encoded,
    epochs=50,
    batch_size=64,
    validation_split=0.2,
    callbacks=[early_stop, checkpoint],
    verbose=1
)

# Evaluate combined model
final_score = combined_model.evaluate(
    [X_test_cnn[:, :split, :], X_test_cnn[:, split:, :], mlp_test],
    y_test_encoded
)

print("Final Combined Accuracy:", final_score[1])
